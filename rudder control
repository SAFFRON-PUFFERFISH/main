#include <Servo.h> 

#include <XBOXONE.h> 

Servo rightf; //fin servos
Servo leftf;

USB Usb; //initilises USB host
XBOXONE Xbox(&Usb); //creates controller object

//SET UP PINS

int servrf 0;
int servlf 0;


bool right = false;
bool left = false;
bool button = false;

void setup() {
  //set joysticks as inputs and stepper motors as outputs
Serial.begin(115200);


while (!Serial); // Wait for serial port to connect - used on Leonardo, Teensy and other boards with built-in USB CDC serial connection
  if (Usb.Init() == -1) {
    Serial.print(F("\r\nOSC did not start"));
    while (1); //halt
  }

  rightf.attach(servrf);
  leftf.attach(servlf);

}

void loop() {

  Usb.Task(); //processes USB events

  if (Xbox.getButtonClick(A)){
     button = !button;
}

  int16_t joystick = Xbox.getAnalogHat(LeftHatX); //horizontal, y axis is irrelevent to us, range -32768 to 32767

  

 
    if (joystick < -7500){
     turnr();
  
    }
 
    else if (joystick > 7500){
      turnl();
 
   }

    else {
    straight(); //default set to straight


    

  }

  delay(10);

}







void turnr() {
  
  if (left) {

    if (!button){
       leftf.write(0); //all angle writes need to be adjusted depending on the motor we use
       }
    else {
      leftf.write(180);
    }
   
    left = !left;

  }

  if (!right) {
    
    rightf.write(90);
    

    right = !right;

  }

}

void turnl() {

  if (right){
    if (!button){
      rightf.write(0); //all angle writes need to be adjusted depending on the motor we use
    }
    else {
      rightf.write(180);
    }
    
    right = !right;
  }

  if (!left){
    
    leftf.write(90);
    left = !left;
  }

}

void straight(){

  if (right){
    if (!button){
      rightf.write(0); //all angle writes need to be adjusted depending on the motor we use
    }
    else {
      rightf.write(180);
    }
  
    right = !right;

  }

  if (left) {
    if (!button){
       leftf.write(0); //all angle writes need to be adjusted depending on the motor we use
       }
    else {
      leftf.write(180);
    }
   
   
    left = !left;

  }

}

