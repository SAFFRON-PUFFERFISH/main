#include <servo.h> 

Servo rightf; //fin servos
Servo leftf;



//SET UP PINS

int servrf ;
int servlf ;


bool right = false;
bool left = true;
bool button = false;

void setup() {
  //set joysticks as inputs and stepper motors as outputs

  rightf.attach(sevrf);
  leftf.attach(sevlf);
  

}

void loop() {


  //read joystick x values

  switch (joystick) {
    case "":
     turnr();
  
    break;
 
    case "":
      turnl();
 
    break;

    default:
    straight(); //default set to straight


    break;
  }

}





void turnr() {
  
  if left = "true" {

    if button = "false"{
       leftf.write(0); //all angle writes need to be adjusted depending on the motor we use
       }
    else {
      leftf.write(180);
    }
   
    left = !left;

  }

  if right = "false" {
   
    rightf.write(90);
    right = !right;

  }

}

void turnl() {

  if right = "true"{
    if button = "false"{
      rightf.write(0); //all angle writes need to be adjusted depending on the motor we use
    }
    else {
      rightf.write(180);
    }
    
    right = !right;
  }

  if left = "false"{
    
    leftf.write(90);
    left = !left;
  }

}

void straight(){

  if right = "true"{
    if button = "false"{
      rightf.write(0); //all angle writes need to be adjusted depending on the motor we use
    }
    else {
      rightf.write(180);
    }
  
    right = !right;

  }

  if left = "true"{
    if button = "false"{
       leftf.write(0); //all angle writes need to be adjusted depending on the motor we use
       }
    else {
      leftf.write(180);
    }
   
   
    left = !left;

  }

}

