#include <Servo.h> //library to interface with servos

#include <XBOXONE.h> //library to use xbox one controller

Servo rightf; //fin servos
Servo leftf;

USB Usb; //initilises USB host
XBOXONE Xbox(&Usb); //creates controller object

//SET UP PINS

int servrf 0;
int servlf 0;


bool right = false;
bool left = false;
bool button = false;

void setup() {
 
Serial.begin(115200); //set baud rate


while (!Serial); // wait for serial port to connect
  if (Usb.Init() == -1) {
    Serial.print(F("\r\nOSC did not start"));
    while (1); //halt
  }

  rightf.attach(servrf);
  leftf.attach(servlf);

}

void loop() {

  Usb.Task(); //processes USB events

  if (Xbox.getButtonClick(A)){ //if the button has been pressed, change the button bool to let the software know
     button = !button;
}
  //using right hand joystick for horizontal deflection
  int16_t joystick = Xbox.getAnalogHat(RightHatX); //horizontal, y axis is irrelevent to us, range -32768 to 32767

  

 
    if (joystick < -7500){ //includes a dead zone of 7500 (May need to be adjusted)
     turnl();
  
    }
 
    else if (joystick > 7500){
      turnr();
 
   }

    else {
    straight(); //default set to straight


    

  }

  delay(10); //small delay to keep things running smoother

}







void turnr() {
  
  if (left) {

    if (!button){
       leftf.write(0); //all angle writes need to be adjusted depending on the motor we use
       }
    else {
      leftf.write(180); // if button is pressed fin closes the other way
    }
   
    left = !left;

  }

  if (!right) {
    
    rightf.write(90);
    

    right = !right;

  }

}

void turnl() {

  if (right){
    if (!button){
      rightf.write(0); //all angle writes need to be adjusted depending on the motor we use
    }
    else {
      rightf.write(180);
    }
    
    right = !right;
  }

  if (!left){
    
    leftf.write(90);
    left = !left;
  }

}

void straight(){

  if (right){
    if (!button){
      rightf.write(0); //all angle writes need to be adjusted depending on the motor we use
    }
    else {
      rightf.write(180);
    }
  
    right = !right;

  }

  if (left) {
    if (!button){
       leftf.write(0); //all angle writes need to be adjusted depending on the motor we use
       }

    else {
      leftf.write(180);
    }
   
   
    left = !left;

  }

}

